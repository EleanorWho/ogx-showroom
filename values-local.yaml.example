# Local configuration for llama-stack-showroom
#
# Copy this file and fill in your values:
#   cp values-local.yaml.example values-local.yaml
#
# This file is used by:
#   - helm-provision.sh (llamastack section, passed via -f to Helm)
#   - setup.sh (cluster section)
#   - deploy-local.sh (devLocal section)
#   - test.sh, demos (model names, openaiApiKey)
#
# values-local.yaml is gitignored — do not commit it.

# ============================================================
# LlamaStack Helm values (consumed by charts/llama-stack-rhoai)
# ============================================================
# Keys under "llamastack:" are passed to the Helm chart and injected
# into the LlamaStack pod as env vars. Any value that the LlamaStack
# server needs at runtime MUST go here — including API keys, auth
# settings, provider config, and resource limits.
# See charts/llama-stack-rhoai/values.yaml for the full list.
llamastack:
  inference:
    model: llama-3-2-3b
    vllmUrl: ""              # REQUIRED: e.g. https://your-vllm-inference-endpoint/v1
    vllmApiToken: ""         # REQUIRED: your inference API token

  embedding:
    model: nomic-embed-text-v1.5
    providerModelId: nomic-ai/nomic-embed-text-v1.5
    dimension: "768"
    vllmUrl: ""              # REQUIRED: e.g. https://your-vllm-embedding-endpoint/v1
    vllmApiToken: ""         # REQUIRED: your embedding API token

  # OpenAI API key (for multi-agent demo — passed to LlamaStack server)
  openaiApiKey: ""

# ============================================================
# Cluster setup (used by setup-cluster.sh)
# ============================================================
cluster:
  # REQUIRED: base64-encoded quay.io credentials
  # To generate:
  #   1. Go to quay.io -> Account Settings -> CLI Password -> Generate Encrypted Password
  #   2. Run: podman login --authfile /tmp/ps.json -u='<user>' -p='<pass>' quay.io
  #   3. Extract: cat /tmp/ps.json | jq -r '.auths["quay.io"].auth'
  pullSecret: ""

  # Optional overrides (defaults are usually fine)
  catalogImage: ""           # default: quay.io/rhoai/rhoai-fbc-fragment:rhoai-3.4
  operatorChannel: ""        # default: stable-3.4
  llamaStackImage: ""        # custom LlamaStack image (for testing)
  operatorImage: ""          # custom operator image (for testing)

# ============================================================
# Local dev deployment (used by deploy-local.sh)
# ============================================================
devLocal:
  llamaStackSourcePath: ""   # e.g. ~/projects/llama-stack
  imageNamespace: ""         # default: redhat-ods-applications
  imageName: ""              # default: llama-stack-dev
  imageTag: ""               # default: auto-generated with timestamp
  baseImage: ""              # default: auto-detected from operator
  containerTool: ""          # default: podman

